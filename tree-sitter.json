{
  "grammars": [
    {
      "name": "koja",
      "camelcase": "Koja",
      "scope": "source.koja",
      "path": ".",
      "file-types": ["koja", "kojs"],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Koja programming language",
    "authors": [
      {
        "name": "Henry Popp",
        "email": "hello@hpopp.dev"
      }
    ],
    "links": {
      "repository": "https://github.com/koja-lang/tree-sitter-koja"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
