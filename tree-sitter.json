{
  "grammars": [
    {
      "name": "expo",
      "camelcase": "Expo",
      "scope": "source.expo",
      "path": ".",
      "file-types": [
        "expo"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Expo programming language",
    "authors": [
      {
        "name": "Henry Popp",
        "email": "hello@hpopp.dev"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-expo"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
